---
import "@fontsource-variable/geist-mono";
import { BellOff } from "lucide-react";

const categorizedItems = [
  {
    category: {
      name: "Small Plates",
      description:
        "A collection of seasonal compositions designed to open the meal with balance, texture, and brightness.",
    },
    items: [
      {
        name: "Heirloom Tomato Tartare",
        description:
          "Vine-ripened tomatoes, basil oil, shaved fennel, and sea salt on toasted sourdough.",
        price: "$14",
      },
      {
        name: "Seared Scallops",
        description:
          "Golden caramelized scallops, citrus emulsion, and tender young herbs.",
        price: "$18",
      },
      {
        name: "Truffle Mushroom Croquettes",
        description:
          "Crisp exterior, creamy woodland mushroom center, finished with aged pecorino.",
        price: "$16",
      },
    ],
  },
  {
    category: {
      name: "Entrees",
      description:
        "Thoughtfully sourced ingredients prepared with restraint and precision.",
    },
    items: [
      {
        name: "Roasted Duck Breast",
        description:
          "Slow-roasted duck, cherry gastrique, and charred broccolini.",
        price: "$32",
      },
      {
        name: "Wild Mushroom Risotto",
        description:
          "Arborio rice, forest mushrooms, white wine, and aged parmesan.",
        price: "$28",
      },
      {
        name: "Charred Wagyu Short Rib",
        description: "Tender wagyu, smoked jus, and creamy pomme purée.",
        price: "$38",
      },
    ],
  },
  {
    category: {
      name: "Desserts",
      description: "Elegant finishes crafted to linger.",
    },
    items: [
      {
        name: "Valrhona Chocolate Soufflé",
        description: "Dark chocolate soufflé with crème anglaise.",
        price: "$12",
      },
      {
        name: "Lavender Panna Cotta",
        description:
          "Silken cream infused with lavender, served with macerated berries.",
        price: "$10",
      },
    ],
  },
];
---

<section class="my-28 space-y-6 px-4 max-w-xl mx-auto">
  <div>
    <h2 class="text-center text-xl font-medium">
      Simple for customers. <br />Even simpler for you.
    </h2>
    <p class="text-center mt-2">
      Customers scan, browse, and decide in seconds. You can add or update items
      anytime, with no printing, no delays, and instant QR access.
    </p>
  </div>
  <div
    class="relative w-xs h-160 border-[3px] border-black bg-[#f4f4f0] shadow-[20px_20px_0px_0px_rgba(0,0,0,0.1)] overflow-hidden flex flex-col mx-auto rounded-2xl"
  >
    <div
      class="h-6 border-b bg-white flex justify-between items-center px-3 font-mono text-[11px]"
    >
      <div class="flex items-center gap-1">
        <span id="device-local-time" aria-live="off" class="tracking-tight">
          <span data-time-hours>--</span><span class="time-colon">:</span><span
            data-time-minutes>--</span
          >
        </span>
        <BellOff className="fill-black size-2.5" />
      </div>
      <div class="flex gap-1">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="24"
          height="24"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="size-5"
          ><path d="M2 20h.01"></path><path d="M7 20v-4"></path><path
            d="M12 20v-8"></path><path d="M17 20V8"></path></svg
        >
      </div>
    </div>

    <div class="flex-1 overflow-y-auto no-scrollbar device-preview">
      <div class="p-4 text-center mb-4">
        <h3 class="text-lg font-medium">Maison Ember</h3>
        <ul
          class="text-[10px] opacity-60 mt-1 flex items-center justify-center gap-3"
        >
          {categorizedItems.map((set) => <li>{set.category.name}</li>)}
        </ul>
      </div>
      <div class="space-y-8 pb-4">
        {
          categorizedItems.map((set) => (
            <div>
              <div class="px-4">
                <span class="text-xs font-medium block">
                  {set.category.name}
                </span>
                <p class="text-[10px] opacity-60 leading-tight">
                  {set.category.description}
                </p>
                <span class="w-full block border-b h-px my-1 mb-2" />
              </div>
              <div class="space-y-3 px-4">
                {set.items.map((item) => (
                  <div>
                    <div class="flex items-center justify-between mb-1 gap-6">
                      <span class="text-xs">{item.name}</span>
                      <span class="text-xs">{item.price}</span>
                    </div>
                    <p class="text-[10px] opacity-60 leading-tight max-w-3/4">
                      {item.description}
                    </p>
                  </div>
                ))}
              </div>
            </div>
          ))
        }
      </div>
    </div>

    <div class="h-12 border-t bg-white flex items-center justify-around">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="24"
        height="24"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        class="text-neutral-500 size-5"
        ><path d="m12 19-7-7 7-7"></path><path d="M19 12H5"></path></svg
      >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="24"
        height="24"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        class="text-neutral-500 size-5"
        ><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path></svg
      >

      <!-- Plus Circle -->
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="24"
        height="24"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        class="text-neutral-500 size-5"
        ><circle cx="12" cy="12" r="10"></circle><path d="M8 12h8"></path><path
          d="M12 8v8"></path></svg
      >

      <!-- Browser Square -->
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="24"
        height="24"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        class="text-neutral-500 size-5"
        ><rect width="18" height="18" x="3" y="3" rx="5"></rect></svg
      >

      <!-- 3 Dots -->
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="24"
        height="24"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        class="text-neutral-500 size-5"
        ><circle cx="12" cy="12" r="1"></circle><circle cx="19" cy="12" r="1"
        ></circle><circle cx="5" cy="12" r="1"></circle></svg
      >
    </div>
  </div>
</section>

<style>
  .device-preview::-webkit-scrollbar {
    width: 6px;
  }

  .device-preview::-webkit-scrollbar-track {
    background: transparent;
  }

  .device-preview::-webkit-scrollbar-thumb {
    background-color: rgba(0, 0, 0, 0.2);
    border-radius: 999px;
  }
</style>

<script>
  const timeElement = document.getElementById("device-local-time");

  if (timeElement) {
    const hoursElement = timeElement.querySelector("[data-time-hours]");
    const minutesElement = timeElement.querySelector("[data-time-minutes]");
    let intervalId = 0;
    let timeoutId = 0;

    const updateTime = () => {
      if (!hoursElement || !minutesElement) return;

      const now = new Date();
      const hours = now.getHours();
      const displayHours = ((hours + 11) % 12) + 1;
      const minutes = String(now.getMinutes()).padStart(2, "0");
      hoursElement.textContent = String(displayHours);
      minutesElement.textContent = minutes;
    };

    updateTime();

    const now = new Date();
    const delayUntilNextMinute =
      (60 - now.getSeconds()) * 1000 - now.getMilliseconds();

    timeoutId = window.setTimeout(() => {
      updateTime();
      intervalId = window.setInterval(updateTime, 60_000);
    }, delayUntilNextMinute);

    window.addEventListener(
      "pagehide",
      () => {
        window.clearTimeout(timeoutId);
        window.clearInterval(intervalId);
      },
      { once: true },
    );
  }
</script>
