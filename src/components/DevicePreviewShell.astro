---
import DevicePreviewTime from "@/components/DevicePreviewTime";

type Props = {
  class?: string;
};

const { class: className = "" } = Astro.props;
---

<div
  class:list={[
    "relative mx-auto flex h-160 w-86.25 flex-col overflow-hidden rounded-3xl border-[3px] border-black bg-[#f4f4f0] shadow-[20px_20px_0px_0px_rgba(0,0,0,0.1)]",
    className,
  ]}
>
  <div
    class="flex h-8 items-center justify-between border-b bg-white px-3 font-mono text-[11.5px]"
  >
    <div class="flex items-center gap-1">
      <DevicePreviewTime client:load />
      <svg
        aria-hidden="true"
        class="size-2.5 fill-black"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <path
          d="M10.27 5.27A2 2 0 0 1 12 4a6 6 0 0 1 6 6v3.5l1.7 2.55A1 1 0 0 1 18.87 17H17"
        ></path>
        <path
          d="M6.33 8.33A5.98 5.98 0 0 0 6 10v3.5l-1.7 2.55A1 1 0 0 0 5.13 17H15"
        ></path>
        <path d="M10 20a2 2 0 0 0 4 0"></path>
        <path d="m2 2 20 20"></path>
      </svg>
    </div>
    <div class="flex items-center gap-1.5">
      <svg
        aria-hidden="true"
        class="size-4"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <path d="M2 20h.01"></path>
        <path d="M7 20v-4"></path>
        <path d="M12 20v-8"></path>
        <path d="M17 20V8"></path>
        <path d="M22 4v16"></path>
      </svg>
      <svg
        aria-hidden="true"
        class="size-3.5"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <path d="M12 20h.01"></path>
        <path d="M2 8.82a15 15 0 0 1 20 0"></path>
        <path d="M5 12.86a10 10 0 0 1 14 0"></path>
        <path d="M8.5 16.43a5 5 0 0 1 7 0"></path>
      </svg>
      <svg
        aria-hidden="true"
        class="size-4"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <path class="stroke-green-500" d="m11 7-3 5h4l-3 5"></path>
        <path d="M14.856 6H16a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2h-2.935"></path>
        <path d="M22 14v-4"></path>
        <path d="M5.14 18H4a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h2.936"></path>
      </svg>
    </div>
  </div>

  <div class="device-preview flex-1 overflow-hidden">
    <slot />
  </div>

  <div class="flex items-center justify-around border-t bg-white py-3">
    <svg
      aria-hidden="true"
      class="size-5 text-neutral-500"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
    >
      <path d="m12 19-7-7 7-7"></path>
      <path d="M19 12H5"></path>
    </svg>
    <svg
      aria-hidden="true"
      class="size-5 text-neutral-500"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
    >
      <path d="M5 12h14"></path>
      <path d="m12 5 7 7-7 7"></path>
    </svg>
    <svg
      aria-hidden="true"
      class="size-5 text-neutral-500"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
    >
      <circle cx="12" cy="12" r="10"></circle>
      <path d="M8 12h8"></path>
      <path d="M12 8v8"></path>
    </svg>
    <svg
      aria-hidden="true"
      class="size-5 text-neutral-500"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
    >
      <rect width="18" height="18" x="3" y="3" rx="2"></rect>
    </svg>
    <svg
      aria-hidden="true"
      class="size-5 text-neutral-500"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
    >
      <circle cx="12" cy="12" r="1"></circle>
      <circle cx="19" cy="12" r="1"></circle>
      <circle cx="5" cy="12" r="1"></circle>
    </svg>
  </div>
</div>
