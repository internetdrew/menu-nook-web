---
import {
  Card,
  CardContent,
  CardDescription,
  CardFooter,
  CardHeader,
  CardTitle,
} from "./ui/card";
import {
  Code2,
  ExternalLink,
  ListCollapse,
  ScanQrCode,
  Smartphone,
} from "lucide-react";
---

<section class="my-28 space-y-6 px-4 max-w-xl mx-auto">
  <div class="text-center space-y-2 max-w-xs mx-auto">
    <h2 class="text-xl font-medium">Try it out or see how it's built.</h2>
    <p class="text-sm max-w-md mx-auto">
      Simple menu publishing for cafes, bakeries, pop-ups, and small food
      businesses.
    </p>
  </div>

  <Card className="mx-auto sm:max-w-sm">
    <CardHeader>
      <CardTitle>Explore MenuNook</CardTitle>
      <CardDescription className="text-sm">
        Open the live demo to try it, or view the source on GitHub.
      </CardDescription>
    </CardHeader>
    <CardContent className="space-y-3">
      <a
        href="https://demo.menunook.com"
        class="bg-neutral-950 text-white px-4 py-2 block text-center rounded-lg
  hover:bg-neutral-800 transition text-sm w-full"
      >
        View live demo
      </a>
      <a
        href="https://github.com/internetdrew/menu-nook-app"
        class="border border-border px-4 py-2 block text-center rounded-lg hover:bg-
  neutral-50 transition text-sm w-full"
      >
        View source
      </a>
    </CardContent>
    <CardFooter className="flex-col items-start gap-2">
      <p class="text-sm text-muted-foreground">Inside the demo:</p>
      <ul class="space-y-2 font-medium">
        <li class="text-sm flex items-center gap-2">
          <Smartphone className="size-4 text-pink-600 shrink-0" />
          A clean menu built for mobile
        </li>
        <li class="text-sm flex items-center gap-2">
          <ScanQrCode className="size-4 text-pink-600 shrink-0" />
          Simple sharing by link or QR code
        </li>
        <li class="text-sm flex items-center gap-2">
          <ListCollapse className="size-4 text-pink-600 shrink-0" />
          Easy menu updates and organization
        </li>
        <li class="text-sm flex items-center gap-2">
          <Code2 className="size-4 text-pink-600 shrink-0" />
          Source available to explore on GitHub
        </li>
      </ul>
    </CardFooter>
  </Card>
</section>
