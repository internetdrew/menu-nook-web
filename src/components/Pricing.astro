---
import { Check } from "lucide-react";
---

<section class="mt-28 mb-14 space-y-6 px-6 max-w-md mx-auto">
  <div class="text-center space-y-2 mx-auto">
    <h2 class="text-lg font-bold">At a price that actually makes sense</h2>
    <p class="mx-auto">
      One live menu. One monthly price.<br /> Nothing extra to manage.
    </p>
  </div>

  <div
    class="bg-white border border-neutral-200 rounded-lg py-7 px-6 space-y-5 max-w-md mx-auto shadow-[0_10px_30px_rgba(0,0,0,0.08),0_1px_2px_rgba(0,0,0,0.06)]"
  >
    <div class="space-y-1">
      <p class="flex items-baseline gap-2">
        <span class="text-4xl font-bold tracking-tight">$5</span>
        <span class="text-sm font-medium text-neutral-600"
          >per menu, monthly</span
        >
      </p>
      <p class="text-neutral-700 text-sm leading-snug">
        For sellers who need to update items, prices, and sold-out status
        without rebuilding a menu.
      </p>
    </div>

    <div class="space-y-3">
      <p class="text-sm font-medium text-left">
        Everything you need to stay current:
      </p>
      <ul class="space-y-2.5 text-neutral-700">
        <li class="flex items-start gap-2 text-sm leading-snug">
          <Check className="size-3.5 text-pink-600 shrink-0 mt-0.5" />
          Share a clean mobile menu by link or QR code
        </li>
        <li class="flex items-start gap-2 text-sm leading-snug">
          <Check className="size-3.5 text-pink-600 shrink-0 mt-0.5" />
          Organize items into simple sections
        </li>
        <li class="flex items-start gap-2 text-sm leading-snug">
          <Check className="size-3.5 text-pink-600 shrink-0 mt-0.5" />
          Update names, prices, and availability in seconds
        </li>
        <li class="flex items-start gap-2 text-sm leading-snug">
          <Check className="size-3.5 text-pink-600 shrink-0 mt-0.5" />
          Changes show up instantly, no reprinting
        </li>
      </ul>
    </div>

    <div class="space-y-2">
      <a
        href="https://app.menunook.com"
        class="inline-flex h-10 w-full items-center justify-center gap-2 whitespace-nowrap rounded-md bg-primary px-6 text-sm font-medium text-primary-foreground transition-all hover:bg-primary/90 focus-visible:border-ring focus-visible:ring-ring/50 focus-visible:ring-[3px] outline-none duration-300 disabled:pointer-events-none disabled:opacity-50 hover:shadow-[0_6px_20px_rgba(0,0,0,0.12)]"
      >
        Create your menu
      </a>
      <p class="text-center text-xs text-neutral-500">
        Start in minutes. Cancel anytime.
      </p>
    </div>
  </div>
</section>

<style>
  h2 {
    font-family: "Playfair Display Variable", serif;
  }
</style>
