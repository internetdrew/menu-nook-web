---
import {
  Card,
  CardContent,
  CardDescription,
  CardFooter,
  CardHeader,
  CardTitle,
} from "./ui/card";
import { CircleCheck } from "lucide-react";
---

<section class="my-28 space-y-6 px-4 max-w-xl mx-auto">
  <h2 class="text-center text-xl font-medium">Pricing</h2>
  <Card className="mx-auto sm:max-w-md">
    <CardHeader>
      <CardTitle className="text-xl">Pro</CardTitle>
      <CardDescription>
        Elevate your menus and delight your guests.
      </CardDescription>
    </CardHeader>
    <CardContent>
      <div class="flex items-end gap-1 mb-6">
        <span class="font-medium text-4xl inline-flex items-center"
          ><span class="text-lg">$</span>25</span
        >
        <span class="text-muted-foreground text-sm">per month, per menu</span>
      </div>
      <a
        href="https://app.menunook.com"
        class="bg-neutral-950 text-white px-4 py-2 block text-center rounded-lg hover:bg-neutral-800 transition text-sm w-full"
      >
        Get Started
      </a>
    </CardContent>
    <CardFooter className="flex-col items-start gap-2">
      <p class="text-sm text-muted-foreground">What's included:</p>
      <ul class="space-y-1.5">
        <li class="text-sm flex items-center gap-2">
          <CircleCheck
            className="size-4 fill-pink-600/5 stroke-pink-600 shrink-0"
          />Unlimited dishes and menu changes
        </li>
        <li class="text-sm flex items-center gap-2">
          <CircleCheck
            className="size-4 fill-pink-600/5 stroke-pink-600 shrink-0"
          />Add photos, video, and/or audio to any item
        </li>
        <li class="text-sm flex items-center gap-2">
          <CircleCheck
            className="size-4 fill-pink-600/5 stroke-pink-600 shrink-0"
          />Changes go live instantly
        </li>
        <li class="text-sm flex items-center gap-2">
          <CircleCheck
            className="size-4 fill-pink-600/5 stroke-pink-600 shrink-0"
          />Human support when you need it
        </li>
      </ul>
    </CardFooter>
  </Card>
</section>
