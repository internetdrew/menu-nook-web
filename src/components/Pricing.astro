---
import { Check } from "lucide-react";
---

<section class="mt-28 mb-14 space-y-6 px-6 max-w-md mx-auto">
  <div class="text-center space-y-2 max-w-xs mx-auto">
    <h2 class="text-xl font-medium">Simple, straightforward pricing.</h2>
    <p class="max-w-md mx-auto font-light">
      Everything you need to create and share your menu. Nothing extra to
      manage.
    </p>
  </div>

  <div
    class="bg-neutral-300/20 border border-neutral-200 rounded-lg py-8 px-6 space-y-6 max-w-sm mx-auto shadow"
  >
    <div>
      <p class="text-lg font-semibold">$10 per menu, monthly</p>
      <p class="text-neutral-700 text-sm">
        Start with one menu. Add more anytime.
      </p>
    </div>

    <a
      href="https://app.menunook.com"
      class="inline-flex h-10 w-full items-center justify-center gap-2 whitespace-nowrap rounded-md bg-primary px-6 text-sm font-medium text-primary-foreground transition-all hover:bg-primary/90 focus-visible:border-ring focus-visible:ring-ring/50 focus-visible:ring-[3px] outline-none duration-300 disabled:pointer-events-none disabled:opacity-50 hover:shadow-[0_6px_20px_rgba(0,0,0,0.12)]"
    >
      Create your page
    </a>

    <div>
      <p class="text-sm mb-2 text-left">What you get:</p>
      <ul class="space-y-2 text-neutral-700">
        <li class="flex items-center gap-1 text-sm">
          <Check className="size-3.5 text-neutral-600/70 shrink-0" />
          Clean, mobile-friendly menu page
        </li>
        <li class="flex items-center gap-1 text-sm">
          <Check className="size-3.5 text-neutral-600/70 shrink-0" />
          Share instantly by link or QR code
        </li>
        <li class="flex items-center gap-1 text-sm">
          <Check className="size-3.5 text-neutral-600/70 shrink-0" />
          Organize items into simple sections
        </li>
        <li class="flex items-center gap-1 text-sm">
          <Check className="size-3.5 text-neutral-600/70 shrink-0" />
          Update names, prices, and specials in seconds
        </li>
        <li class="flex items-center gap-1 text-sm">
          <Check className="size-3.5 text-neutral-600/70 shrink-0" />
          Changes show up right away
        </li>
      </ul>
    </div>
  </div>
</section>
