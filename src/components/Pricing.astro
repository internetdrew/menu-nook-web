---
import {
  Card,
  CardContent,
  CardDescription,
  CardFooter,
  CardHeader,
  CardTitle,
} from "./ui/card";
import { CircleCheck } from "lucide-react";
---

<section class="my-28 space-y-6 px-4 max-w-xl mx-auto">
  <h2 class="text-center text-xl font-medium">
    Simple pricing for a menu that stays current.
  </h2>
  <Card className="mx-auto sm:max-w-sm">
    <CardHeader>
      <CardTitle>Pro</CardTitle>
      <CardDescription className="text-sm">
        Everything you need to keep your menu online and easy to update.
      </CardDescription>
    </CardHeader>
    <CardContent>
      <div class="gap-1 mb-6">
        <span class="font-medium text-4xl inline-flex items-center">$10</span>
        <span class="block text-muted-foreground text-xs pb-1"
          >per menu / month</span
        >
      </div>
      <a
        href="https://app.menunook.com"
        class="bg-neutral-950 text-white px-4 py-2 block text-center rounded-lg hover:bg-neutral-800 transition text-sm w-full"
      >
        Create your menu
      </a>
    </CardContent>
    <CardFooter className="flex-col items-start gap-2">
      <p class="text-sm text-muted-foreground">What's included:</p>
      <ul class="space-y-1.5">
        <li class="text-sm flex items-center gap-2">
          <CircleCheck
            className="size-4 fill-pink-600/5 stroke-pink-600 shrink-0"
          />Unlimited items and updates
        </li>
        <li class="text-sm flex items-center gap-2">
          <CircleCheck
            className="size-4 fill-pink-600/5 stroke-pink-600 shrink-0"
          />Share by link or QR code
        </li>
        <li class="text-sm flex items-center gap-2">
          <CircleCheck
            className="size-4 fill-pink-600/5 stroke-pink-600 shrink-0"
          />Changes go live instantly
        </li>
        <li class="text-sm flex items-center gap-2">
          <CircleCheck
            className="size-4 fill-pink-600/5 stroke-pink-600 shrink-0"
          />Clean mobile menu layout
        </li>
        <li class="text-sm flex items-center gap-2">
          <CircleCheck
            className="size-4 fill-pink-600/5 stroke-pink-600 shrink-0"
          />Support when you need it
        </li>
      </ul>
    </CardFooter>
  </Card>
</section>
