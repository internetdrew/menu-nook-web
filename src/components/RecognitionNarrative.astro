---
import "@fontsource-variable/playfair-display/wght.css";
import MenuEditorPreview from "@/components/MenuEditorPreview";
import DevicePreviewShell from "@/components/DevicePreviewShell.astro";
---

<section class="my-28 space-y-6 px-6 max-w-lg mx-auto text-center">
  <div class="space-y-2">
    <h2 class="text-lg font-bold">Your menu shouldn't be another project.</h2>
    <p>
      Make quick changes without turning updates into another task to manage.
    </p>
  </div>
  <DevicePreviewShell>
    <MenuEditorPreview client:load />
  </DevicePreviewShell>
</section>

<style>
  h2 {
    font-family: "Playfair Display Variable", serif;
  }
</style>
