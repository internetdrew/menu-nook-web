---
import { SolutionItem } from "./SolutionItem";
---

<section class="my-28 space-y-6 px-4 max-w-md mx-auto">
  <h2 class="text-center text-xl max-w-xs mx-auto font-medium">
    MenuNook helps you keep your menu clear and up to date.
  </h2>
  <ul class="max-w-sm mx-auto">
    <SolutionItem
      client:load
      icon="pencil"
      title="Update items, prices, and specials anytime"
    />
    <SolutionItem
      client:load
      icon="qr-code"
      title="Share one simple menu by link or QR code"
    />
    <SolutionItem
      client:load
      icon="smartphone"
      title="Keep the menu easy to read on any phone"
    />
    <SolutionItem
      client:load
      icon="refresh-cw"
      title="Make changes once and they show up immediately"
    />
  </ul>
</section>
