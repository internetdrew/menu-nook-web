---
import DevicePreviewShell from "@/components/DevicePreviewShell.astro";
import MenuPreviewScreen from "@/components/MenuPreviewScreen";
---

<section class="my-28 space-y-6 px-6 max-w-lg mx-auto">
  <div class="text-center">
    <h2 class="text-lg font-bold">What your customers see</h2>
    <p>A polished mobile menu that reflects your latest updates.</p>
  </div>
  <DevicePreviewShell>
    <MenuPreviewScreen client:load />
  </DevicePreviewShell>
</section>

<style>
  h2 {
    font-family: "Playfair Display Variable", serif;
  }
</style>
