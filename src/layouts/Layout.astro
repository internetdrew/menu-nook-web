---
import "../styles/global.css";
import "@fontsource-variable/ibm-plex-sans/wght.css";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <meta name="generator" content={Astro.generator} />
    <title>Simple Shareable Catalog Pages | MenuNook</title>
    <meta
      name="description"
      content="Create clean, shareable pages for products, services, specials, or offerings without managing a full website."
    />

    <!-- Facebook Meta Tags -->
    <meta property="og:url" content="https://www.menunook.com/" />
    <meta property="og:type" content="website" />
    <meta
      property="og:title"
      content="Simple Shareable Catalog Pages | MenuNook"
    />
    <meta
      property="og:description"
      content="Create clean, shareable pages for products, services, specials, or offerings without managing a full website."
    />
    <meta property="og:image" content="https://www.menunook.com/og.png" />
    <meta property="og:image:alt" content="MenuNook app preview" />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <!-- Twitter Meta Tags -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta property="twitter:domain" content="www.menunook.com" />
    <meta property="twitter:url" content="https://www.menunook.com/" />
    <meta
      name="twitter:title"
      content="Simple Shareable Catalog Pages | MenuNook"
    />
    <meta
      name="twitter:description"
      content="Create a clean, shareable page for products, services, specials, or offerings without managing a full website."
    />
    <meta name="twitter:image" content="https://www.menunook.com/og.png" />
    <meta name="twitter:image:alt" content="MenuNook app preview" />
  </head>
  <body class="bg-stone-100">
    <main>
      <slot />
    </main>
    <footer>
      <div
        class="max-w-xl mx-auto text-center mb-16 px-4 text-sm text-neutral-600"
      >
        <p>&copy; {new Date().getFullYear()} MenuNook. All rights reserved.</p>
        <a
          href="https://internetdrew.com"
          class="underline underline-offset-4 decoration-neutral-300 hover:decoration-neutral-500 hover:text-neutral-700 transition duration-300"
          >An InternetDrew Experience</a
        >
      </div>
    </footer>
  </body>
</html>

<script></script>

<style>
  html,
  body {
    font-family: "IBM Plex Sans Variable", sans-serif;
  }
</style>
